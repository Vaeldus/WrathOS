#!/bin/bash
set -e

echo "Fixing live boot kernel filename..."

cd live

echo "Contents of live directory before fix:"
ls -la

# Copy instead of symlink so GRUB can find it
cp vmlinuz-6.19.9-cachy vmlinuz-amd64
cp initrd.img-6.19.9-cachy initrd.img-amd64

echo "Contents of live directory after fix:"
ls -la

