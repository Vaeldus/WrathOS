#!/bin/bash
set -e

echo "Configuring KDE system defaults..."

# Remove plasma-welcome package entirely
apt-get remove -y --purge plasma-welcome 2>/dev/null || true

# Remove any remaining welcome autostart files
find /etc/xdg/autostart -name "*welcome*" -delete 2>/dev/null || true
find /usr/share/autostart -name "*welcome*" -delete 2>/dev/null || true

# System-wide KDE defaults
mkdir -p /etc/xdg
cat > /etc/xdg/plasma-welcomescreen.conf << 'KDEEOF'
[General]
ShouldShow=false
KDEEOF

# Disable session restore system-wide so wallpaper config is always read
cat > /etc/xdg/ksmserverrc << 'KDEEOF'
[General]
loginMode=default
KDEEOF

# Skel configs for all new users
mkdir -p /etc/skel/.config
mkdir -p /etc/skel/.config/autostart

cat > /etc/skel/.config/plasma-welcomescreen.conf << 'KDEEOF'
[General]
ShouldShow=false
KDEEOF

cat > /etc/skel/.config/plasma-org.kde.plasma.desktop-appletsrc << 'KDEEOF'
[Containments][1][Wallpaper][org.kde.image][General]
Image=file:///usr/share/wallpapers/WrathOS/wrathos-default.png
KDEEOF

cat > /etc/skel/.config/kiorc << 'KDEEOF'
[Executable scripts]
behaviourOnLaunch=execute
KDEEOF

cat > /etc/skel/.config/ksmserverrc << 'KDEEOF'
[General]
loginMode=default
KDEEOF

# Wallpaper autostart for all users
cat > /etc/skel/.config/autostart/wrathos-wallpaper.desktop << 'DESKEOF'
[Desktop Entry]
Type=Application
Name=WrathOS Wallpaper Setup
Exec=/usr/bin/wrathos-set-wallpaper.sh
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
DESKEOF

echo "KDE system defaults configured."
