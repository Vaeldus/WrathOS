#!/bin/bash
set -e

echo "Setting WrathOS system identity..."

cat > /etc/lsb-release << 'LSBEOF'
DISTRIB_ID=WrathOS
DISTRIB_RELEASE=0.1
DISTRIB_CODENAME=trixie
DISTRIB_DESCRIPTION="WrathOS 0.1 (trixie)"
LSBEOF

echo "wrathos/trixie" > /etc/debian_version
echo "wrathos" > /etc/hostname

echo "WrathOS system identity configured."
