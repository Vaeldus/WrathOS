#!/bin/bash

LIVE_USER="user"
LIVE_HOME="/home/${LIVE_USER}"

for i in $(seq 1 30); do
    [ -d "$LIVE_HOME" ] && break
    sleep 1
done

[ -d "$LIVE_HOME" ] || exit 0

mkdir -p "${LIVE_HOME}/.config"
mkdir -p "${LIVE_HOME}/.config/autostart"

cat > "${LIVE_HOME}/.config/plasma-welcomescreen.conf" << 'KDEEOF'
[General]
ShouldShow=false
KDEEOF

cat > "${LIVE_HOME}/.config/kiorc" << 'KDEEOF'
[Executable scripts]
behaviourOnLaunch=execute
KDEEOF

# Set folder view containment using kwriteconfig6
sudo -u "$LIVE_USER" DBUS_SESSION_BUS_ADDRESS="" \
    kwriteconfig6 \
    --file plasma-org.kde.plasma.desktop-appletsrc \
    --group "Containments][1][General" \
    --key "plugin" \
    --type string "org.kde.plasma.folder" 2>/dev/null || true

cat > "${LIVE_HOME}/.config/autostart/wrathos-wallpaper.desktop" << 'DESKEOF'
[Desktop Entry]
Type=Application
Name=WrathOS Wallpaper Setup
Exec=/usr/bin/wrathos-set-wallpaper.sh
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
DESKEOF

# Restart plasmashell after KDE starts to apply folder view
cat > "${LIVE_HOME}/.config/autostart/wrathos-plasma-restart.desktop" << 'DESKEOF'
[Desktop Entry]
Type=Application
Name=WrathOS Plasma Init
Exec=bash -c "sleep 5 && kwriteconfig6 --file plasma-org.kde.plasma.desktop-appletsrc --group 'Containments][1][General' --key plugin --type string org.kde.plasma.folder && plasmashell --replace > /dev/null 2>&1 &"
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
DESKEOF

chown -R "${LIVE_USER}:${LIVE_USER}" "${LIVE_HOME}/.config"
