#!/bin/bash
set -e

echo "Installing WrathOS media codecs bundle..."

apt-get install -y \
    ffmpeg \
    gstreamer1.0-plugins-good \
    gstreamer1.0-plugins-bad \
    gstreamer1.0-plugins-ugly \
    gstreamer1.0-libav \
    libdvdread8 \
    libdvdnav4

flatpak install -y flathub org.videolan.VLC 2>/dev/null || \
    apt-get install -y vlc

echo "Media codecs bundle installation complete."
